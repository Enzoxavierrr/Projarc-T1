meta {
  name: Submeter Pedido
  type: http
  seq: 1
}

post {
  url: {{base_url}}/pedidos/submeter
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "itens": [
      {
        "produtoId": 2,
        "quantidade": 1
      }
    ],
    "enderecoEntrega": "Rua das Flores, 100"
  }
}

vars:pre-request {
  base_url: http://localhost:8080
}
